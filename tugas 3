<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tugas 3: Logika Login - EDUTRAIL LIBRARY</title>
    
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #6b4527;
            --secondary: #c8a97e;
            --dark: #3a2416;
            --light: #f7efe6;
            --accent: #8b5e3c;
            --black-coffee: #1a100a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Poppins', sans-serif; background-color: #fffaf3; color: #3e2a1c; line-height: 1.6; }

        /* ===== HEADER & TOP BAR (Sesuai Homepage) ===== */
        .top-bar {
            background: var(--black-coffee);
            color: var(--secondary);
            padding: 8px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
        }
        header {
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, var(--dark), var(--black-coffee));
            color: white;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo-area { display: flex; align-items: center; gap: 12px; }
        .logo-area img { width: 45px; height: 45px; border-radius: 50%; border: 2px solid var(--secondary); }
        .logo-text h2 { font-size: 16px; letter-spacing: 1px; line-height: 1; }
        .logo-text span { font-size: 10px; color: var(--secondary); text-transform: uppercase; }

        .nav-menu a {
            text-decoration: none;
            color: #e6d3b2;
            font-size: 13px;
            padding: 8px 12px;
            border-radius: 8px;
            transition: 0.3s;
        }

        /* ===== AREA LOGIN ===== */
        .login-section {
            padding: 60px 5%;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 70vh;
        }

        .login-container {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border: 1px solid var(--secondary);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        .login-container h3 {
            color: var(--dark);
            margin-bottom: 10px;
        }

        .login-container p.subtitle {
            font-size: 12px;
            color: #666;
            margin-bottom: 30px;
        }

        .input-group { margin-bottom: 20px; text-align: left; }
        .input-group label { display: block; font-size: 14px; margin-bottom: 8px; font-weight: 600; color: var(--primary); }
        .input-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-family: 'Poppins';
            outline: none;
            transition: 0.3s;
        }
        .input-group input:focus { border-color: var(--secondary); box-shadow: 0 0 8px rgba(200, 169, 126, 0.2); }

        .btn-login {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--primary), var(--dark));
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins';
            transition: 0.3s;
            font-size: 16px;
        }
        .btn-login:hover { transform: scale(1.02); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

        /* Status Messages */
        #message-box {
            margin-top: 25px;
            padding: 15px;
            border-radius: 10px;
            font-size: 14px;
            display: none; /* Sembunyi secara default */
        }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .warning { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }

        /* ===== FOOTER (Sesuai Homepage) ===== */
        footer {
            background: var(--black-coffee);
            color: #d1bfa7;
            padding: 60px 8% 30px;
            margin-top: 50px;
        }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; }
        .footer-col h4 { color: white; margin-bottom: 20px; position: relative; }
        .footer-col h4::after { content:''; position:absolute; left:0; bottom:-5px; width:30px; height:2px; background:var(--secondary); }
        .dosen-info { margin-top: 30px; text-align: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; font-style: italic; }
    </style>
</head>
<body>

<div class="top-bar">
    <div><i class="material-icons" style="font-size: 14px;">security</i> Sistem Autentikasi Perpustakaan</div>
    <div>Puti Hani Alwafi (230709021)</div>
</div>

<header>
    <div class="logo-area">
        <img src="logo.png.png" alt="Logo">
        <div class="logo-text">
            <h2>EDUTRAIL LIBRARY</h2>
            <span>Pathway to Knowledge</span>
        </div>
    </div>
    <nav class="nav-menu">
        <a href="tugas-kuliah.html">Kembali ke Daftar Tugas</a>
    </nav>
</header>

<section class="login-section">
    <div class="login-container">
        <span class="material-icons" style="font-size: 60px; color: var(--secondary); margin-bottom: 15px;">account_circle</span>
        <h3>Member Login</h3>
        <p class="subtitle">Silakan masukkan kredensial Anda untuk mengakses koleksi.</p>
        
        <div class="input-group">
            <label>ID / Username</label>
            <input type="text" id="username" placeholder="Contoh: putihani">
        </div>

        <div class="input-group">
            <label>Password</label>
            <input type="password" id="password" placeholder="••••••••">
        </div>

        <button class="btn-login" onclick="validasiLogin()">MASUK KE AKUN</button>

        <div id="message-box"></div>
    </div>
</section>

<footer>
    <div class="footer-grid">
        <div class="footer-col">
            <h4>EDUTRAIL LIBRARY</h4>
            <p style="font-size: 13px;">Tugas 3 - Logika Pemrograman Web</p>
        </div>
        <div class="footer-col">
            <h4>Dosen Pengampu</h4>
            <p style="font-size: 14px;">Himma Dewiyana ST., M.Hum.</p>
        </div>
    </div>
    <div class="dosen-info">
        &copy; 2026 Edutrail Library. Dikembangkan dengan dedikasi untuk literasi Indonesia.
    </div>
</footer>

<script>
    function validasiLogin() {
        // Ambil nilai input
        const user = document.getElementById('username').value.trim();
        const pass = document.getElementById('password').value.trim();
        const box = document.getElementById('message-box');

        // Data login yang benar (Hanya contoh)
        const validUser = "admin";
        const validPass = "12345";

        // Tampilkan box
        box.style.display = 'block';

        // Logika 3 Kondisi
        if (user === "" || pass === "") {
            // Kondisi 3: Input tidak lengkap
            box.className = "warning";
            box.innerHTML = "<strong>Peringatan!</strong> Input tidak lengkap. Mohon isi Username dan Password.";
        } 
        else if (user === validUser && pass === validPass) {
            // Kondisi 1: Login Sukses
            box.className = "success";
            box.innerHTML = "<strong>Berhasil!</strong> Login sukses. Selamat datang di Edutrail Library.";
        } 
        else {
            // Kondisi 2: Login Gagal
            box.className = "error";
            box.innerHTML = "<strong>Gagal!</strong> ID atau Password salah. Silakan coba lagi.";
        }
    }
</script>

</body>
</html>